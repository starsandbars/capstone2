    "eq.heaviness.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Some days carry more weight. Noticing that takes courage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos días llevan más peso. Notarlo requiere valentía."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certains jours sont plus lourds. Le remarquer demande du courage."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有些日子会承载更多，注意到这一点需要勇气。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alguns dias carregam mais peso. Notar isso requer coragem."
