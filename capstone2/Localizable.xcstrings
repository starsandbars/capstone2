    "eq.loneliness.question": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "How lonely or isolated have you been feeling?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cuánta soledad o aislamiento has estado sintiendo?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À quel point vous êtes-vous senti seul ou isolé ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您感到多大程度的孤独或隔离？"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanta solidão ou isolamento você tem sentido?"
          }
        }
      }
    },
    "eq.loneliness.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Connection matters. Sharing how you feel is a brave first step."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conexión importa. Compartir cómo te sientes es un primer paso valiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion est importante. Partager vos sentiments est un premier pas courageux."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "联系很重要，分享您的感受是勇敢的第一步。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conexão importa. Compartilhar como você se sente é um primeiro passo corajoso."
          }
        }
      }
    },
