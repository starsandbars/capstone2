    "eq.anger.detail" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "It's okay to feel angry. This is a safe place to be honest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Está bien sentir enfado. Este es un lugar seguro para ser honesto."
