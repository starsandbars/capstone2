    "eq.heaviness.question": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "How emotionally heavy has the day felt for you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué tan emocionalmente pesado ha sido el día para ti?"
