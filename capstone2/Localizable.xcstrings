    "eq.anxiety.question": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "How worried or anxious have you felt about your recovery or health?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cuánta preocupación o ansiedad has sentido sobre tu recuperación o salud?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À quel point vous êtes-vous senti inquiet ou anxieux concernant votre rétablissement ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您对康复或健康感到多大的担忧或焦虑？"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanta preocupação ou ansiedade você sentiu sobre sua recuperação ou saúde?"
          }
        }
      }
    },
    "eq.anxiety.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Anxiety about recovery is very common. You're not alone in this."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ansiedad por la recuperación es muy común. No estás solo en esto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'anxiété face au rétablissement est très courante. Vous n'êtes pas seul."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对康复感到焦虑非常普遍，您并不孤单。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A ansiedade sobre a recuperação é muito comum. Você não está sozinho nisso."
          }
        }
      }
    },
    "eq.anxiety.high": {
      "localizations": {
