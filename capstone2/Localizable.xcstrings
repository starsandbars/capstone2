    "eq.anger.question": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "How much anger or frustration have you noticed in yourself?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cuánto enfado o frustración has notado en ti mismo?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle quantité de colère ou de frustration avez-vous ressentie ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您在自己身上注意到了多少愤怒或沮丧？"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanta raiva ou frustração você notou em si mesmo?"
          }
        }
      }
    },
    "eq.anger.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "It's okay to feel angry. This is a safe place to be honest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Está bien sentir enfado. Este es un lugar seguro para ser honesto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il est normal de ressentir de la colère. C'est un espace sûr pour être honnête."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感到愤怒是正常的，这里是一个安全的地方，请诚实地表达。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É normal sentir raiva. Este é um lugar seguro para ser honesto."
          }
        }
      }
    },
    "eq.anger.high": {
      "localizations": {
